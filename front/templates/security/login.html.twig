{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="col-6 offset-3">
        <h1 class="h3 mb-3">Connexion</h1>

        {% for label in ['success', 'danger'] %}
            {% for message in app.flashes(label) %}
                <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <form action="{{ path('app_login') }}" method="post">
            <label for="username">Email</label>
            <input type="email" name="_username" id="username" class="form-control mb-3" autocomplete="email" required autofocus>
            <label for="password">Mot de passe</label>
            <input type="password" name="_password" id="password" class="form-control mb-3" autocomplete="current-password" required>
            <button class="btn btn-lg btn-primary" type="submit">Se connecter</button>
        </form>

        <p class="mt-3">
            <a href="{{ path('app_register') }}">Créer un compte</a>
        </p>
    </div>
{% endblock %}
