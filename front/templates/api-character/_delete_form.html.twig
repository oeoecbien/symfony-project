<form method="post" action="{{ path('app_character_delete', {'identifier': character.identifier}) }}" class="d-inline" onsubmit="return confirm('Confirmer la suppression de ce personnage ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ character.identifier) }}">
    <button type="submit" class="{{ button_class|default('btn btn-danger') }}">Supprimer</button>
</form>
